# Server-only credentials
ELEVENLABS_API_KEY=xi_...
ELEVENLABS_INTAKE_AGENT_ID=
ELEVENLABS_NEGOTIATOR_AGENT_ID=
ELEVENLABS_OUTBOUND_PHONE_NUMBER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ANTHROPIC_API_KEY=sk-ant-...
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
GOOGLE_MAPS_API_KEY=

# Required on Vercel so calls initiated by one serverless instance can be found
# by webhook and status requests handled by another instance.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Upstash's Vercel integration can alternatively provide these names.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# With the custom prefix `UPSTASH_REDIS_REST`, Vercel currently injects:
# UPSTASH_REDIS_REST_KV_REST_API_URL and UPSTASH_REDIS_REST_KV_REST_API_TOKEN.

# Browser-safe agent identifier for the intake voice widget
NEXT_PUBLIC_ELEVENLABS_INTAKE_AGENT_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000
